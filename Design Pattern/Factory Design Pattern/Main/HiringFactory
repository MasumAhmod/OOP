
package com.mycompany.factory_design_pattern;

/**
 *
 * @author Masum
 */
public class HiringFactory {
     Interview requestInterview(String type) {
        HiringManager manager;

        if(type.equals("Dev")) {
            manager = new DevManager();
        }
        else {
            manager = new SQAManager();
        }
        return manager.createInterview();
    }
}
